---
const { guide } = Astro.props;

// Turn a plain-text body (paragraphs split by \n\n, bullet lines starting "• ")
// into structured blocks for clean, framework-y rendering.
function blocks(body) {
  return (body || '').split(/\n\n+/).map((chunk) => {
    const lines = chunk.split('\n').map((l) => l.trim()).filter(Boolean);
    if (lines.length && lines.every((l) => l.startsWith('•'))) {
      return { type: 'list', items: lines.map((l) => l.replace(/^•\s*/, '')) };
    }
    return { type: 'p', text: chunk.replace(/\n/g, ' ') };
  });
}
const sections = (guide?.sections || []).map((s, i) => ({ ...s, blocks: blocks(s.body), open: i === 0 }));
---
<section class="guide">
  <div class="ghead">
    <p class="kicker">Before You Begin</p>
    <h2 class="gtitle">The Reading Guide</h2>
    {guide?.tagline && <p class="gtag">{guide.tagline}</p>}
  </div>

  <div class="gsections">
    {sections.map((s, i) => (
      <details class="gsec" open={s.open}>
        <summary>
          <span class="gn">{String(i + 1).padStart(2, '0')}</span>
          <span class="gt">{s.title}</span>
          <span class="gchev">▾</span>
        </summary>
        <div class="gbody">
          {s.blocks.map((b) => (
            b.type === 'list'
              ? <ul>{b.items.map((it) => <li>{it}</li>)}</ul>
              : <p>{b.text}</p>
          ))}
        </div>
      </details>
    ))}
  </div>
</section>

<style>
  .guide{margin:8px 0 0}
  .ghead{text-align:center; margin:18px 0 22px}
  .gtitle{font-family:var(--display); font-weight:600; font-size:clamp(28px,7vw,40px); margin:0; letter-spacing:-.01em}
  .gtag{font-style:italic; color:var(--ink-soft); max-width:48ch; margin:12px auto 0; font-size:16px}
  .gsec{background:var(--card); border:1px solid var(--line); border-radius:13px; margin:10px 0; box-shadow:var(--shadow); overflow:hidden}
  .gsec summary{list-style:none; cursor:pointer; display:flex; align-items:center; gap:13px; padding:16px 18px}
  .gsec summary::-webkit-details-marker{display:none}
  .gn{font-family:var(--display); font-weight:600; color:var(--rust); font-size:14px; font-variant-numeric:tabular-nums}
  .gt{font-family:var(--display); font-weight:600; font-size:18px; flex:1}
  .gchev{color:var(--ink-faint); transition:transform .25s; font-size:13px}
  .gsec[open] .gchev{transform:rotate(180deg)}
  .gbody{padding:0 18px 18px; border-top:1px solid var(--line)}
  .gbody p{margin:13px 0 0; color:var(--ink-soft); font-size:15.5px}
  .gbody ul{margin:12px 0 0; padding-left:20px}
  .gbody li{margin:7px 0; color:var(--ink-soft); font-size:15px}
  .gbody li::marker{color:var(--gold)}
</style>
