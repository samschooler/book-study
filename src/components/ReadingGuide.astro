---
const { guide } = Astro.props;

// Turn a plain-text body (paragraphs split by \n\n, bullet lines starting "• ")
// into structured blocks.
function blocks(body) {
  return (body || '').split(/\n\n+/).map((chunk) => {
    const lines = chunk.split('\n').map((l) => l.trim()).filter(Boolean);
    if (lines.length && lines.every((l) => l.startsWith('•'))) {
      return { type: 'list', items: lines.map((l) => l.replace(/^•\s*/, '')) };
    }
    return { type: 'p', text: chunk.replace(/\n/g, ' ') };
  });
}
const sections = (guide?.sections || []).map((s) => ({ ...s, blocks: blocks(s.body) }));
---
{/* The list is a TRACK SELECTOR only — clicking a row loads that section into the
    featured canvas above (see the page script). Content is not shown inline here;
    it lives in the hidden <template>s below and is rendered into the canvas. */}
<div class="rg" id="reading-guide" data-rg data-rg-total={sections.length}>
  {guide?.tagline && <p class="rg-tag">{guide.tagline}</p>}
  <div class="tracklist" data-tracklist>
    {sections.map((s, i) => (
      <button class="track" data-gi={i} type="button">
        <span class="tk-n">{String(i + 1).padStart(2, '0')}</span>
        <span class="tk-t">{s.title}</span>
        <span class="tk-badge tk-next">Up next</span>
        <span class="tk-badge tk-done">✓ read</span>
        <span class="tk-play">Read ›</span>
      </button>
    ))}
  </div>
  {sections.map((s, i) => (
    <template class="rg-src" data-gi={i}>
      {s.blocks.map((b) => (
        b.type === 'list'
          ? <ul>{b.items.map((it) => <li>{it}</li>)}</ul>
          : <p>{b.text}</p>
      ))}
    </template>
  ))}
</div>

<style>
  .rg{margin:14px 0 0}
  .rg-tag{font-style:italic; color:var(--ink-soft); font-size:15px; margin:0 2px 14px}
  .tracklist{display:flex; flex-direction:column; gap:8px}
  .track{display:flex; align-items:center; gap:13px; width:100%; text-align:left; cursor:pointer;
    background:var(--card); border:1px solid var(--line); border-left:3px solid transparent; border-radius:12px;
    padding:14px 16px; box-shadow:var(--shadow); font-family:var(--serif);
    -webkit-tap-highlight-color:transparent; transition:border-color .2s, background .2s, transform .12s}
  .track:hover{border-color:var(--olive)}
  .track:active{transform:translateY(1px)}
  .tk-n{font-family:var(--display); font-weight:600; color:var(--rust); font-size:14px; font-variant-numeric:tabular-nums; transition:color .2s}
  .tk-t{font-family:var(--display); font-weight:600; font-size:16px; flex:1; min-width:0}
  .tk-badge{font-size:11px; font-weight:600; border-radius:20px; padding:3px 9px; white-space:nowrap; display:none}
  .tk-next{color:#fff; background:var(--gold)}
  .tk-done{color:var(--olive-deep); background:#e3e8d4}
  .tk-play{font-family:var(--display); font-weight:600; color:var(--olive-deep); font-size:13px; white-space:nowrap}

  /* next (first unread) */
  .track.next{border-left-color:var(--gold); background:#faf4e4}
  .track.next .tk-next{display:inline-block}
  /* done */
  .track.done .tk-n{color:var(--olive-deep)}
  .track.done .tk-t{color:var(--ink-faint)}
  .track.done .tk-done{display:inline-block}
  .track.done .tk-play{color:var(--ink-faint)}
  /* currently shown in the canvas */
  .track.active{border-color:var(--olive-deep); border-left-color:var(--olive-deep); background:#eef1e3}
  .track.active .tk-play{color:var(--olive-deep)}
  .track.active .tk-play::after{content:" (showing)"}
</style>
